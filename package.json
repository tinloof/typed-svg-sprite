{
  "name": "typed-svg-sprite",
  "version": "1.0.0",
  "description": "Generate optimized SVG sprites with full TypeScript support",
  "bin": {
    "typed-svg-sprite": "./dist/cli.js"
  },
  "exports": {
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "clean": "rimraf dist"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "svg",
    "sprite",
    "icon",
    "typescript",
    "nextjs",
    "cli"
  ],
  "author": "LHDi <elhadi98@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tinloof/typed-svg-sprite.git"
  },
  "bugs": {
    "url": "https://github.com/tinloof/typed-svg-sprite/issues"
  },
  "homepage": "https://github.com/tinloof/typed-svg-sprite#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "glob": "^10.3.10"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/cheerio": "^0.22.35",
    "typescript": "^5.0.0",
    "rimraf": "^5.0.5"
  }
}

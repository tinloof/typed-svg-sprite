{
  "name": "@tinloof/typed-svg-sprite",
  "version": "0.1.1",
  "description": "Generate optimized SVG sprites with full TypeScript support",
  "bin": {
    "typed-svg-sprite": "./dist/cli.js"
  },
  "exports": {
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "default": "./dist/astro.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "pnpm run build",
    "clean": "rimraf dist",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "svg",
    "sprite",
    "icon",
    "typescript",
    "nextjs",
    "astro",
    "cli"
  ],
  "author": "LHDi <elhadi98@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tinloof/typed-svg-sprite.git"
  },
  "bugs": {
    "url": "https://github.com/tinloof/typed-svg-sprite/issues"
  },
  "homepage": "https://github.com/tinloof/typed-svg-sprite#readme",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "glob": "^10.3.10"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "astro": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20.0.0",
    "astro": "^5.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.0.0"
  }
}
